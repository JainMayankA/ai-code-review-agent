# Copy to .env and fill in values before running

# Required: GitHub Personal Access Token
# Scopes needed: repo, pull_requests
GITHUB_TOKEN=ghp_your_token_here

# Required: Secret used to verify GitHub webhook signatures
# Set this same value in your GitHub App webhook settings
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here

# Required: OpenAI API key for GPT-powered review
OPENAI_API_KEY=sk-your-key-here

# Optional: OpenAI model to use for review
OPENAI_MODEL=gpt-4o

# Optional: set to "true" to review PRs without posting comments back
DRY_RUN=false

# Optional: Markdown file containing your personal review rules
REVIEW_RULES_FILE=review_rules.md

# Optional: set to "true" to fetch related repository files for extra context.
# Keep false if you only want PR changed files reviewed/fetched.
REVIEW_REPO_CONTEXT=false
